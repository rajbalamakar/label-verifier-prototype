# Copy this to .env and fill in your values

# Database
# Local dev (default): SQLite — no setup needed
DATABASE_URL=sqlite+aiosqlite:///./labelcheck.db
# Docker / Cloud Run: swap to Postgres
# DATABASE_URL=postgresql+asyncpg://ttb:ttbpass@localhost:5432/labelcheck

# Google OAuth (leave blank to use dev_mode bypass)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SECRET_KEY=change-me-to-a-long-random-string

# TTB email domain restriction
ALLOWED_EMAIL_DOMAIN=ttb.gov

# Storage: "local" for dev, "gcs" for production
STORAGE_BACKEND=local
UPLOAD_DIR=../uploads
GCS_BUCKET_NAME=

# Dev mode: set to false in production
DEV_MODE=true
DEV_USER_EMAIL=agent@ttb.gov

# Tesseract binary path (Windows only — install from https://github.com/UB-Mannheim/tesseract/wiki)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# OCR backend: "tesseract" for local dev, "paddle" for Docker/prod
OCR_BACKEND=tesseract

# App
BASE_URL=http://localhost:8000
